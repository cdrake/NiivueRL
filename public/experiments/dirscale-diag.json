{
  "name": "dirscale-diag",
  "description": "Direction-scale diagnostic: does amplifying the direction-to-target signal rescue PPO from its random-like performance?",
  "agents": ["ppo", "oracle", "random"],
  "landmarks": ["Thalamus", "Lateral-Ventricle"],
  "episodes": 300,
  "replicates": 2,
  "neighborhood": 7,
  "strides": [1],
  "dirScale": 10,
  "zeroDir": false,
  "maxStartDist": 50,
  "trunk": "flat",
  "ppo": { "lr": 0.0003, "entropy": 0.01, "clip": 0.2, "epochs": 4, "mb": 64, "roll": 4 },
  "autorun": true,
  "autodownload": true,
  "clearCache": true
}
